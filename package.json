{
  "name": "@happy2870/dsk",
  "version": "0.1.0",
  "description": "Design System Kit — A collection of reusable React UI components, hooks, and utilities built with Tailwind CSS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./components/ui": {
      "types": "./dist/components/ui/index.d.ts",
      "import": "./dist/components/ui/index.js",
      "require": "./dist/components/ui/index.cjs"
    },
    "./components/icons": {
      "types": "./dist/components/icons/index.d.ts",
      "import": "./dist/components/icons/index.js",
      "require": "./dist/components/icons/index.cjs"
    },
    "./components/layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/components/layout/index.js",
      "require": "./dist/components/layout/index.cjs"
    },
    "./components/error": {
      "types": "./dist/components/error/index.d.ts",
      "import": "./dist/components/error/index.js",
      "require": "./dist/components/error/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "require": "./dist/stores/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs"
    },
    "./css": "./src/css/base.css"
  },
  "files": [
    "dist",
    "src/css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.17",
    "driver.js": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/react": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.4",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.8.0",
    "simplebar-react": "^3.3.2",
    "storybook": "^10.2.17",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.4.0",
    "typescript": "^5",
    "vite": "^8.0.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "clsx": ">=2",
    "framer-motion": ">=12",
    "next": ">=14",
    "react": ">=18",
    "react-countup": ">=6",
    "react-dom": ">=18",
    "react-tooltip": ">=5",
    "recharts": ">=3",
    "simplebar-react": ">=3",
    "tailwind-merge": ">=3",
    "zustand": ">=5"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "framer-motion": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react-countup": {
      "optional": true
    },
    "react-tooltip": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "simplebar-react": {
      "optional": true
    },
    "zustand": {
      "optional": true
    }
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tailwind",
    "typescript"
  ],
  "author": "happy2870",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/happy2870/dsk.git"
  }
}
